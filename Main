    public static void menuPrincipal() {
        boolean programaActivo = true;

        while (programaActivo) {
            System.out.println("-------- ACCESO A SIFRAH --------");
            System.out.println("Usuario activo: " + usuarioActivo);
            System.out.println("1.- Registrarse");
            System.out.println("2.- Iniciar sesion");
            System.out.println("3.- Entrar como invitado");
            System.out.println("4.- Salir del programa");

            int opcion = leerEntero("Seleccione una opcion: ");

            switch (opcion) {
                case 1:
                    registro();
                    menuTienda();
                    break;
                case 2:
                    if (loginUsuario()) {
                        menuTienda();
                    }
                    break;
                case 3:
                    usuarioActivo = "Invitado";
                    sesionIniciada = false;
                    esAdmin = false;
                    menuTienda();
                    break;
                case 4:
                    System.out.println("Gracias por visitar SIFRAH.");
                    programaActivo = false;
                    break;
                default:
                    System.out.println("Opcion no valida.");
            }
        }
    }

    public static void menuTienda() {
        boolean sesionActiva = true;

        while (sesionActiva) {
            System.out.println("-------- MENU PRINCIPAL --------");
            System.out.println("Usuario activo: " + usuarioActivo);
            System.out.println("Administrador: " + esAdmin);
            System.out.println("1.- Entrar a categorias");
            System.out.println("2.- Ver carrito");
            System.out.println("3.- Finalizar compra");
            System.out.println("4.- Panel de administrador");
            System.out.println("5.- Ofertas aleatorias");
            System.out.println("6.- Estadisticas de precios");
            System.out.println("7.- Libro de reclamaciones");
            System.out.println("8.- Salir de la sesion");

            int opcion = leerEntero("Seleccione una opcion: ");

            switch (opcion) {
                case 1:
                    categorias();
                    break;
                case 2:
                    mostrarCarrito();
                    break;
                case 3:
                    finalizarCompra();
                    break;
                case 4:
                    if (esAdmin) {
                        menuAdminCRUD();
                    } else {
                        System.out.println("Acceso denegado. Solo administrador.");
                    }
                    break;
                case 5:
                    mostrarOfertasAleatorias();
                    break;
                case 6:
                    mostrarEstadisticasPrecios();
                    break;
                case 7:
                    libroReclamaciones();
                    break;
                case 8:
                    cerrarSesion();
                    sesionActiva = false;
                    break;
                default:
                    System.out.println("Opcion no valida.");
            }
        }
    }

    public static void cerrarSesion() {
        usuarioActivo = "Invitado";
        sesionIniciada = false;
        esAdmin = false;
        System.out.println("Sesion cerrada. Volviendo al menu de acceso.");
    }

    public static boolean loginUsuario() {
        System.out.println("----- INICIAR SESION -----");

        for (int intentos = 1; intentos <= 3; intentos++) {
            String correoIn = leerTexto("Ingrese su correo: ");
            String passIn = leerTexto("Ingrese su contrasena: ");

            boolean estructuraCorreoOk = (correoIn.contains("@") && correoIn.endsWith(".com")) || correoIn.equals("admin");
            boolean estructuraPassOk = passIn.length() >= 5;

            if (!estructuraCorreoOk || !estructuraPassOk) {
                System.out.println("Los datos no cumplen los requisitos.");
                System.out.println("Intento " + intentos + " de 3");
            } else {
                for (int i = 0; i < correosUsuarios.size(); i++) {
                    if (correoIn.equals(correosUsuarios.get(i)) && passIn.equals(contrasenasUsuarios.get(i))) {
                        sesionIniciada = true;
                        usuarioActivo = correoIn;
                        esAdmin = correoIn.equals("admin");
                        System.out.println(esAdmin ? "Ingreso exitoso como administrador." : "Ingreso exitoso como cliente.");
                        return true;
                    }
                }

                System.out.println("Credenciales no validas.");
                System.out.println("Intento " + intentos + " de 3");
            }
        }

        System.out.println("Cuenta bloqueada por demasiados intentos.");
        return false;
    }

    public static void registro() {
        boolean registrado = false;

        System.out.println("----- REGISTRO DE CLIENTE -----");

        do {
            String correo = leerTexto("Ingrese su correo electronico: ");
            String contrasena = leerTexto("Ingrese su contrasena: ");

            boolean correoValido = correo.contains("@") && correo.endsWith(".com");
            boolean contrasenaValida = contrasena.length() >= 8;

            if (correoValido && contrasenaValida) {
                if (correosUsuarios.contains(correo)) {
                    System.out.println("Ese correo ya existe.");
                } else {
                    correosUsuarios.add(correo);
                    contrasenasUsuarios.add(contrasena);
                    usuarioActivo = correo;
                    sesionIniciada = true;
                    esAdmin = false;
                    registrado = true;
                    System.out.println("Registro exitoso.");
                }
            } else {
                System.out.println("Datos incorrectos.");
                if (!correoValido) {
                    System.out.println("El correo debe contener @ y terminar en .com");
                }
                if (!contrasenaValida) {
                    System.out.println("La contrasena debe tener minimo 8 caracteres");
                }
            }
        } while (!registrado);
    }

