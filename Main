    public static void menuCategoria(ArrayList<String> productos, ArrayList<Double> precios, String titulo) {
        boolean salir = false;

        do {
            System.out.println("----- " + titulo + " -----");
            System.out.println("1.- Ver productos");
            System.out.println("2.- Ver productos ordenados por nombre");
            System.out.println("3.- Ver productos ordenados por precio");
            System.out.println("4.- Agregar producto al carrito");
            System.out.println("5.- Volver");

            int opcion = leerEntero("Seleccione una opcion: ");

            switch (opcion) {
                case 1:
                    imprimirProductosTienda(productos, precios);
                    break;
                case 2:
                    mostrarOrdenadoPorNombre(productos, precios);
                    break;
                case 3:
                    mostrarOrdenadoPorPrecio(productos, precios);
                    break;
                case 4:
                    seleccionarProducto(productos, precios);
                    break;
                case 5:
                    salir = true;
                    break;
                default:
                    System.out.println("Opcion no valida.");
            }
        } while (!salir);
    }

    public static void seleccionarProducto(ArrayList<String> productos, ArrayList<Double> precios) {
        imprimirProductosTienda(productos, precios);

        int opcion = leerEntero("Seleccione producto: ");

        if (opcion >= 1 && opcion <= productos.size()) {
            int posicion = opcion - 1;
            int cantidad = leerEntero("Ingrese cantidad: ");

            if (cantidad > 0) {
                agregarAlCarrito(productos.get(posicion), cantidad, precios.get(posicion));
            } else {
                System.out.println("Cantidad no valida.");
            }
        } else {
            System.out.println("Producto no valido.");
        }
    }

    public static void agregarAlCarrito(String producto, int cantidad, double precio) {
        boolean existe = false;

        for (int i = 0; i < carritoProductos.size(); i++) {
            if (carritoProductos.get(i).equalsIgnoreCase(producto)) {
                int nuevaCantidad = carritoCantidades.get(i) + cantidad;
                double nuevoSubtotal = nuevaCantidad * precio;
                carritoCantidades.set(i, nuevaCantidad);
                carritoSubtotales.set(i, nuevoSubtotal);
                existe = true;
            }
        }

        if (!existe) {
            carritoProductos.add(producto);
            carritoCantidades.add(cantidad);
            carritoPrecios.add(precio);
            carritoSubtotales.add(cantidad * precio);
        }

        calcularTotalCarrito();
        System.out.println("Producto agregado al carrito.");
        System.out.printf("Total acumulado: S/ %.2f%n", carritoTotal);
    }

    public static void mostrarCarrito() {
        System.out.println("-------- PRODUCTOS EN CARRITO --------");

        if (carritoProductos.isEmpty()) {
            System.out.println("El carrito esta vacio.");
            return;
        }

        for (int i = 0; i < carritoProductos.size(); i++) {
            System.out.printf("%d.- %s | Cantidad: %d | Precio: S/ %.2f | Subtotal: S/ %.2f%n",
                    i + 1, carritoProductos.get(i), carritoCantidades.get(i), carritoPrecios.get(i), carritoSubtotales.get(i));
        }

        System.out.println("Cantidad total de productos: " + contarProductosRecursivo(0));
        System.out.printf("TOTAL: S/ %.2f%n", carritoTotal);
    }

    public static void calcularTotalCarrito() {
        carritoTotal = 0;

        for (double subtotal : carritoSubtotales) {
            carritoTotal += subtotal;
        }
    }

    public static void finalizarCompra() {
        if (carritoProductos.isEmpty()) {
            System.out.println("No puede finalizar compra porque el carrito esta vacio.");
            return;
        }

        calcularTotalCarrito();
        aplicarOfertaAleatoria();
        mostrarCarrito();
        datosEntrega();
        mostrarSucursales();

        boolean pagoCorrecto = pagar(carritoTotal);

        if (pagoCorrecto) {
            carritoProductos.clear();
            carritoCantidades.clear();
            carritoPrecios.clear();
            carritoSubtotales.clear();
            carritoTotal = 0;
        }
    }

    public static void aplicarOfertaAleatoria() {
        int descuento = random.nextInt(4) * 5;

        if (descuento > 0) {
            double montoDescuento = carritoTotal * descuento / 100;
            carritoTotal -= montoDescuento;
            System.out.println("Oferta aleatoria aplicada: " + descuento + "% de descuento.");
            System.out.printf("Ahorro: S/ %.2f%n", montoDescuento);
        } else {
            System.out.println("No se aplico descuento aleatorio en esta compra.");
        }
    }

    public static void datosEntrega() {
        System.out.println("-------- DATOS DE ENTREGA --------");

        do {
            nombreCliente = leerTexto("Ingrese nombre: ");
        } while (nombreCliente.isEmpty());

        do {
            apellidosCliente = leerTexto("Ingrese apellidos: ");
        } while (apellidosCliente.isEmpty());

        do {
            dniCliente = leerTexto("Ingrese DNI de 8 digitos: ");
        } while (!dniCliente.matches("\\d{8}"));

        do {
            telefonoCliente = leerTexto("Ingrese telefono de 9 digitos: ");
        } while (!telefonoCliente.matches("\\d{9}"));
    }

    public static boolean pagar(double total) {
        System.out.println("Seleccione metodo de pago");

        for (int i = 0; i < metodosPago.length; i++) {
            System.out.println((i + 1) + ".- " + metodosPago[i]);
        }

        int opcionPago = leerEntero("Seleccione una opcion: ");

        switch (opcionPago) {
            case 1:
                if (validarPagoTarjeta(total)) {
                    generarBoleta(total, total);
                    return true;
                }
                break;
            case 2:
                return pagoEfectivo(total);
            default:
                System.out.println("Opcion no valida.");
        }

        return false;
    }

    public static boolean validarPagoTarjeta(double total) {
        boolean pagoAprobado = false;

        System.out.printf("Monto total a pagar con tarjeta: S/ %.2f%n", total);

        do {
            String numeroTarjeta = leerTexto("Ingrese los 16 digitos de la tarjeta: ");
            String fechaVencimiento = leerTexto("Ingrese la fecha de caducidad (MM/AA): ");
            String cvv = leerTexto("Ingrese el codigo de seguridad CVV: ");

            boolean tarjetaOk = numeroTarjeta.matches("\\d{16}");
            boolean cvvOk = cvv.matches("\\d{3}");
            boolean fechaOk = validarFechaTarjeta(fechaVencimiento);

            if (tarjetaOk && fechaOk && cvvOk) {
                System.out.println("Autorizando fondos... transaccion exitosa.");
                pagoAprobado = true;
            } else {
                System.out.println("Operacion denegada. Verifique tarjeta, fecha y CVV.");
            }
        } while (!pagoAprobado);

        return true;
    }

    public static boolean validarFechaTarjeta(String fechaVencimiento) {
        try {
            DateTimeFormatter formateador = DateTimeFormatter.ofPattern("MM/yy");
            YearMonth fechaTarjeta = YearMonth.parse(fechaVencimiento, formateador);
            YearMonth fechaActual = YearMonth.now();
            return fechaTarjeta.isAfter(fechaActual) || fechaTarjeta.equals(fechaActual);
        } catch (DateTimeParseException e) {
            return false;
        }
    }

    public static boolean pagoEfectivo(double total) {
        double pago;

        do {
            System.out.printf("Total a pagar: S/ %.2f%n", total);
            pago = leerDouble("Ingrese dinero recibido: ");

            if (pago < total) {
                System.out.println("Monto insuficiente.");
            }
        } while (pago < total);

        generarBoleta(total, pago);
        return true;
    }

    public static void mostrarSucursales() {
        System.out.println("Escoja una sede para recojo en tienda");

        for (int i = 0; i < sucursales.size(); i++) {
            System.out.println((i + 1) + ".- " + sucursales.get(i));
        }

        int opcion = leerEntero("Ingrese una opcion: ");

        if (opcion >= 1 && opcion <= sucursales.size()) {
            sucursalElegida = sucursales.get(opcion - 1);
        } else {
            sucursalElegida = "Sucursal no valida";
        }

        System.out.println("Pedido listo en " + sucursalElegida);
    }

    public static void generarBoleta(double total, double pago) {
        double igv = total * 0.18;
        double subtotal = total - igv;
        double vuelto = pago - total;
        StringBuilder boleta = new StringBuilder();

        boleta.append("================ BOLETA DE VENTA ================");
        boleta.append("SIFRAH BIJOU S.A.C.");
        boleta.append("RUC: 20601466920");
        boleta.append("Cliente: ").append(nombreCliente).append(" ").append(apellidosCliente).append("");
        boleta.append("DNI: ").append(dniCliente).append("\n");
        boleta.append("Telefono: ").append(telefonoCliente).append("\n");
        boleta.append("Sucursal de recojo: ").append(sucursalElegida).append("\n");
        boleta.append("-------------------------------------------------\n");
        boleta.append("PRODUCTOS COMPRADOS");

        for (int i = 0; i < carritoProductos.size(); i++) {
            boleta.append(i + 1).append(".- ").append(carritoProductos.get(i))
                    .append(" | Cantidad: ").append(carritoCantidades.get(i))
                    .append(" | Precio: S/ ").append(String.format("%.2f", carritoPrecios.get(i)))
                    .append(" | Subtotal: S/ ").append(String.format("%.2f", carritoSubtotales.get(i)))
                    .append("\n");
        }

        boleta.append("-------------------------------------------------\n");
        boleta.append(String.format("SUBTOTAL: S/ %.2f%n", subtotal));
        boleta.append(String.format("IGV (18%%): S/ %.2f%n", igv));
        boleta.append(String.format("TOTAL A PAGAR: S/ %.2f%n", total));
        boleta.append(String.format("DINERO RECIBIDO: S/ %.2f%n", pago));
        boleta.append(String.format("VUELTO: S/ %.2f%n", vuelto));
        boleta.append("GRACIAS POR TU COMPRA!\n");
        boleta.append("=================================================\n");

        ultimaBoleta = boleta.toString();
        System.out.println(ultimaBoleta);
        exportarBoletaArchivo(ultimaBoleta);
    }

    public static void exportarBoletaArchivo(String boleta) {
        String nombreArchivo = "boleta_sifrah.txt";

        try (FileWriter writer = new FileWriter(nombreArchivo, true)) {
            writer.write(boleta);
            writer.write(System.lineSeparator());
            System.out.println("Boleta exportada en el archivo: " + nombreArchivo);
        } catch (IOException e) {
            System.out.println("No se pudo exportar la boleta: " + e.getMessage());
        }
    }

    public static void mostrarOfertasAleatorias() {
        ArrayList<String> productos = unirProductos();
        ArrayList<Double> precios = unirPrecios();

        if (productos.isEmpty()) {
            System.out.println("No hay productos registrados.");
            return;
        }

        System.out.println("-------- OFERTAS ALEATORIAS --------");

        for (int i = 1; i <= 3; i++) {
            int posicion = random.nextInt(productos.size());
            int descuento = 10 + random.nextInt(4) * 5;
            double precioOriginal = precios.get(posicion);
            double precioOferta = precioOriginal - (precioOriginal * descuento / 100);

            System.out.printf("%d.- %s | Antes: S/ %.2f | Descuento: %d%% | Ahora: S/ %.2f%n",
                    i, productos.get(posicion), precioOriginal, descuento, precioOferta);
        }
    }

    public static void mostrarEstadisticasPrecios() {
        ArrayList<Double> precios = unirPrecios();

        OptionalDouble precioMaximo = precios.stream().mapToDouble(Double::doubleValue).max();
        OptionalDouble precioMinimo = precios.stream().mapToDouble(Double::doubleValue).min();

        System.out.println("-------- ESTADISTICAS DE PRECIOS --------");

        if (precioMaximo.isPresent() && precioMinimo.isPresent()) {
            System.out.printf("Precio maximo: S/ %.2f%n", precioMaximo.getAsDouble());
            System.out.printf("Precio minimo: S/ %.2f%n", precioMinimo.getAsDouble());
        } else {
            System.out.println("No hay precios para analizar.");
        }
    }

    public static void menuAdminCRUD() {
        int opcion;

        do {
            System.out.println("-------- PANEL ADMINISTRADOR --------");
            System.out.println("1.- Registrar producto en tienda");
            System.out.println("2.- Mostrar productos de tienda");
            System.out.println("3.- Modificar producto de tienda");
            System.out.println("4.- Eliminar producto de tienda");
            System.out.println("5.- Buscar producto de tienda");
            System.out.println("6.- Ver libro de reclamaciones");
            System.out.println("7.- Cerrar panel administrador");

            opcion = leerEntero("Seleccione una opcion: ");

            switch (opcion) {
                case 1:
                    adminCrearProducto();
                    break;
                case 2:
                    adminMostrarProductos();
                    break;
                case 3:
                    adminModificarProducto();
                    break;
                case 4:
                    adminEliminarProducto();
                    break;
                case 5:
                    adminBuscarProducto();
                    break;
                case 6:
                    mostrarReclamos();
                    break;
                case 7:
                    System.out.println("Saliendo del panel administrador...");
                    break;
                default:
                    System.out.println("Opcion no valida.");
            }
        } while (opcion != 7);
    }

    public static int seleccionarCategoriaAdmin() {
        System.out.println("Seleccione categoria de tienda:");
        System.out.println("1.- Bisuteria");
        System.out.println("2.- Bolsos y carteras");
        System.out.println("3.- Accesorios de cabello");
        System.out.println("4.- Complementos");
        System.out.println("5.- Belleza");
        return leerEntero("Categoria: ");
    }

    public static ArrayList<String> obtenerProductosPorCategoria(int categoria) {
        switch (categoria) {
            case 1:
                return bisuteria;
            case 2:
                return bolsosYCarteras;
            case 3:
                return accesoriosCabello;
            case 4:
                return complementos;
            case 5:
                return belleza;
            default:
                return null;
        }
    }

    public static ArrayList<Double> obtenerPreciosPorCategoria(int categoria) {
        switch (categoria) {
            case 1:
                return precioBisuteria;
            case 2:
                return precioBolsosYCarteras;
            case 3:
                return precioAccesoriosCabello;
            case 4:
                return precioComplementos;
            case 5:
                return precioBelleza;
            default:
                return null;
        }
    }

    public static void imprimirProductosTienda(ArrayList<String> productos, ArrayList<Double> precios) {
        for (int i = 0; i < productos.size(); i++) {
            System.out.printf("%d.- %s S/ %.2f%n", i + 1, productos.get(i), precios.get(i));
        }
    }

    public static void mostrarOrdenadoPorNombre(ArrayList<String> productos, ArrayList<Double> precios) {
        ArrayList<Integer> indices = crearIndices(productos.size());
        indices.sort(Comparator.comparing(productos::get));

        for (int indice : indices) {
            System.out.printf("%d.- %s S/ %.2f%n", indice + 1, productos.get(indice), precios.get(indice));
        }
    }

    public static void mostrarOrdenadoPorPrecio(ArrayList<String> productos, ArrayList<Double> precios) {
        ArrayList<Integer> indices = crearIndices(productos.size());
        indices.sort(Comparator.comparing(precios::get));

        for (int indice : indices) {
            System.out.printf("%d.- %s S/ %.2f%n", indice + 1, productos.get(indice), precios.get(indice));
        }
    }

    public static ArrayList<Integer> crearIndices(int cantidad) {
        ArrayList<Integer> indices = new ArrayList<>();

        for (int i = 0; i < cantidad; i++) {
            indices.add(i);
        }

        return indices;
    }

    public static void adminCrearProducto() {
        int categoria = seleccionarCategoriaAdmin();
        ArrayList<String> productos = obtenerProductosPorCategoria(categoria);
        ArrayList<Double> precios = obtenerPreciosPorCategoria(categoria);

        if (productos == null || precios == null) {
            System.out.println("Categoria no valida.");
            return;
        }

        String nombre = leerTexto("Ingrese nombre del nuevo producto: ");
        double precio = leerDouble("Ingrese precio: ");

        if (nombre.isEmpty()) {
            System.out.println("El nombre no puede estar vacio.");
        } else if (precio <= 0) {
            System.out.println("Precio no valido.");
        } else {
            agregarProducto(productos, precios, nombre, precio);
            System.out.println("Producto agregado correctamente.");
        }
    }

    public static void adminMostrarProductos() {
        int categoria = seleccionarCategoriaAdmin();
        ArrayList<String> productos = obtenerProductosPorCategoria(categoria);
        ArrayList<Double> precios = obtenerPreciosPorCategoria(categoria);

        if (productos != null && precios != null) {
            imprimirProductosTienda(productos, precios);
        } else {
            System.out.println("Categoria no valida.");
        }
    }

    public static void adminModificarProducto() {
        int categoria = seleccionarCategoriaAdmin();
        ArrayList<String> productos = obtenerProductosPorCategoria(categoria);
        ArrayList<Double> precios = obtenerPreciosPorCategoria(categoria);

        if (productos == null || precios == null) {
            System.out.println("Categoria no valida.");
            return;
        }

        imprimirProductosTienda(productos, precios);
        int opcion = leerEntero("Ingrese el numero del producto a modificar: ");

        if (opcion >= 1 && opcion <= productos.size()) {
            int posicion = opcion - 1;
            String nuevoNombre = leerTexto("Ingrese nuevo nombre: ");
            double nuevoPrecio = leerDouble("Ingrese nuevo precio: ");

            if (nuevoNombre.isEmpty()) {
                System.out.println("El nombre no puede estar vacio.");
            } else if (nuevoPrecio <= 0) {
                System.out.println("Precio no valido.");
            } else {
                productos.set(posicion, nuevoNombre);
                precios.set(posicion, nuevoPrecio);
                System.out.println("Producto modificado correctamente.");
            }
        } else {
            System.out.println("Producto no valido.");
        }
    }

    public static void adminEliminarProducto() {
        int categoria = seleccionarCategoriaAdmin();
        ArrayList<String> productos = obtenerProductosPorCategoria(categoria);
        ArrayList<Double> precios = obtenerPreciosPorCategoria(categoria);

        if (productos == null || precios == null) {
            System.out.println("Categoria no valida.");
            return;
        }

        imprimirProductosTienda(productos, precios);
        int opcion = leerEntero("Ingrese el numero del producto a eliminar: ");

        if (opcion >= 1 && opcion <= productos.size()) {
            int posicion = opcion - 1;
            productos.remove(posicion);
            precios.remove(posicion);
            System.out.println("Producto eliminado correctamente.");
        } else {
            System.out.println("Producto no valido.");
        }
    }

    public static void adminBuscarProducto() {
        String buscar = leerTexto("Ingrese el nombre del producto a buscar: ");
        boolean encontrado = false;

        encontrado = buscarEnCategoria(bisuteria, precioBisuteria, buscar, "Bisuteria") || encontrado;
        encontrado = buscarEnCategoria(bolsosYCarteras, precioBolsosYCarteras, buscar, "Bolsos y carteras") || encontrado;
        encontrado = buscarEnCategoria(accesoriosCabello, precioAccesoriosCabello, buscar, "Accesorios de cabello") || encontrado;
        encontrado = buscarEnCategoria(complementos, precioComplementos, buscar, "Complementos") || encontrado;
        encontrado = buscarEnCategoria(belleza, precioBelleza, buscar, "Belleza") || encontrado;

        if (!encontrado) {
            System.out.println("Producto no encontrado.");
        }
    }

    public static boolean buscarEnCategoria(ArrayList<String> productos, ArrayList<Double> precios, String buscar, String categoria) {
        boolean encontrado = false;

        for (int i = 0; i < productos.size(); i++) {
            if (productos.get(i).toLowerCase().contains(buscar.toLowerCase())) {
                System.out.println("Producto encontrado");
                System.out.println("Categoria: " + categoria);
                System.out.println("Numero: " + (i + 1));
                System.out.println("Nombre: " + productos.get(i));
                System.out.printf("Precio: S/ %.2f%n", precios.get(i));
                encontrado = true;
            }
        }

        return encontrado;
    }

    public static void libroReclamaciones() {
        System.out.println("-------- LIBRO DE RECLAMACIONES --------");
        System.out.println("De acuerdo a lo establecido en el codigo de Proteccion y Defensa del Consumidor Sifrah Bijou SAC con RUC 20601466920 y direccion Av. El Derby Nro. 254 urb. El Derby De Monterrico, distrito de Santiago de Surco, provincia y departamento de Lima, cuenta con un Libro de Reclamaciones a su disposicion*");
        System.out.println("Al ingresar sus datos en el Libro de Reclamaciones usted esta aceptando el tratamiento de sus datos personales para la solucion de su reclamo*");
        String nombre = leerTexto("Ingrese su nombre completo: ");
        String dni = leerTexto("Ingrese su DNI: ");
        String detalle = leerTexto("Describa su reclamo: ");

        if (nombre.isEmpty() || dni.isEmpty() || detalle.isEmpty()) {
            System.out.println("No se registro el reclamo porque hay datos vacios.");
            return;
        }

        String reclamo = "Cliente: " + nombre + " | DNI: " + dni + " | Reclamo: " + detalle;
        reclamos.add(reclamo);
        exportarReclamoArchivo(reclamo);
        System.out.println("Su reclamo fue registrado correctamente.");
    }

    public static void mostrarReclamos() {
        System.out.println("-------- RECLAMOS REGISTRADOS --------");

        if (reclamos.isEmpty()) {
            System.out.println("No hay reclamos registrados en esta sesion.");
            return;
        }

        for (int i = 0; i < reclamos.size(); i++) {
            System.out.println((i + 1) + ".- " + reclamos.get(i));
        }
    }

    public static void exportarReclamoArchivo(String reclamo) {
        try (FileWriter writer = new FileWriter("libro_reclamaciones.txt", true)) {
            writer.write(reclamo);
            writer.write(System.lineSeparator());
        } catch (IOException e) {
            System.out.println("No se pudo guardar el reclamo: " + e.getMessage());
        }
    }

    public static ArrayList<String> unirProductos() {
        ArrayList<String> productos = new ArrayList<>();
        productos.addAll(bisuteria);
        productos.addAll(bolsosYCarteras);
        productos.addAll(accesoriosCabello);
        productos.addAll(complementos);
        productos.addAll(belleza);
        return productos;
    }

    public static ArrayList<Double> unirPrecios() {
        ArrayList<Double> precios = new ArrayList<>();
        precios.addAll(precioBisuteria);
        precios.addAll(precioBolsosYCarteras);
        precios.addAll(precioAccesoriosCabello);
        precios.addAll(precioComplementos);
        precios.addAll(precioBelleza);
        return precios;
    }

    public static int contarProductosRecursivo(int indice) {
        if (indice >= carritoCantidades.size()) {
            return 0;
        }

        return carritoCantidades.get(indice) + contarProductosRecursivo(indice + 1);
    }

    public static String leerTexto(String mensaje) {
        System.out.print(mensaje);
        return scanner.nextLine().trim();
    }

    public static int leerEntero(String mensaje) {
        while (true) {
            System.out.print(mensaje);
            String entrada = scanner.nextLine();

            try {
                return Integer.parseInt(entrada);
            } catch (NumberFormatException e) {
                System.out.println("Ingrese un numero entero valido.");
            }
        }
    }

    public static double leerDouble(String mensaje) {
        while (true) {
            System.out.print(mensaje);
            String entrada = scanner.nextLine().replace(",", ".");

            try {
                return Double.parseDouble(entrada);
            } catch (NumberFormatException e) {
                System.out.println("Ingrese un numero decimal valido.");
            }
        }
    }
}
